#!/bin/bash
#
# Pre-push hook for d3cblog
#
# This hook runs checks before pushing to ensure code quality.
# To use this hook:
#
#   1. Copy this file to .git/hooks/pre-push
#   2. Make it executable: chmod +x .git/hooks/pre-push
#   3. Hook will run automatically when you do: git push origin main
#
# To skip this hook in an emergency:
#   git push --no-verify origin main
#

set -e

echo "🔍 Running pre-push checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to run a check
run_check() {
    local name=$1
    local command=$2

    echo -n "  $name ... "
    if eval "$command" > /dev/null 2>&1; then
        echo -e "${GREEN}✓${NC}"
        return 0
    else
        echo -e "${RED}✗${NC}"
        return 1
    fi
}

# Track failures
FAILED=0

echo "Security checks:"
if ! run_check "Security audit" "bundle audit"; then
    FAILED=$((FAILED + 1))
fi

echo ""
echo "Build checks:"
if ! run_check "Production build" "JEKYLL_ENV=production bundle exec jekyll build --quiet"; then
    FAILED=$((FAILED + 1))
fi

echo ""

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All checks passed!${NC}"
    echo ""
    echo "Your code is ready to push."
    exit 0
else
    echo -e "${RED}❌ $FAILED check(s) failed${NC}"
    echo ""
    echo "Please fix the issues before pushing."
    echo ""
    echo "To skip pre-push checks (not recommended):"
    echo "  git push --no-verify origin main"
    echo ""
    exit 1
fi

