# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# See https://editorconfig.org for details

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 100

# YAML configuration files
[*.{yml,yaml}]
indent_style = space
indent_size = 2
max_line_length = 120

# Ruby files
[*.rb]
indent_style = space
indent_size = 2

# HTML templates
[*.html]
indent_style = space
indent_size = 2

# CSS/SCSS
[*.{css,scss}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Gemfile
[Gemfile]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

